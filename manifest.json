{
  "manifest_version": 3,
  "name": "Website Blocker",
  "version": "1.0.0",
  "description": "Block distracting websites with a Be Aware reminder page.",
  "author": "Ronald Martins Cruz",
  "permissions": ["declarativeNetRequest", "storage", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/shared/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/toolbar-popup/toolbar-popup.html"
  },
  "options_page": "src/settings-page/settings-page.html",
  "web_accessible_resources": [
    {
      "resources": ["src/be-aware-page/be-aware-page.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
